---
const year = new Date().getFullYear()

const footerNavItems = [
  {
    name: 'Privacy Policy',
    href: '/privacy-policy/',
  },
  {
    name: 'Imprint',
    href: '/imprint/',
  },
]

const currentPath = new URL(Astro.request.url).pathname
---

<footer
  class="mx-auto mt-16 max-w-5xl border-t border-slate-100 text-slate-500 sm:px-8 dark:border-slate-700/60 dark:text-slate-200"
>
  <section class="bg-white px-4 dark:bg-gray-800">
    <div class="py-16">
      <div>
        <p class="mb-8 text-center text-sm font-medium">
          Powered by

          <a
            href="https://astro.build"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Astro"
            class="focus-ring"
          >
            <img
              src="/icons/astro-icon-dark.svg"
              alt=""
              width="63"
              height="79"
              class="mr-3 ml-1 inline-block h-5 w-auto dark:hidden"
              loading="lazy"
            />
            <img
              src="/icons/astro-icon-light.svg"
              alt=""
              width="63"
              height="79"
              class="mr-3 ml-1 hidden h-5 w-auto dark:inline-block"
              loading="lazy"
            />
          </a>. Fueled by

          <a
            href="https://www.starbucksathome.com"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Starbucks coffee"
            class="focus-ring"
          >
            <img
              src="/icons/starbucks.svg"
              alt=""
              width="237.4"
              height="240.3"
              class="mr-3 ml-1 inline-block h-5 w-auto"
              loading="lazy"
            />
          </a>. Coded with

          <a
            href="https://code.visualstudio.com"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Visual Studio Code"
            class="focus-ring"
          >
            <img
              src="/icons/vscode.svg"
              alt=""
              width="100"
              height="100"
              class="ml-1 inline-block h-5 w-auto"
              loading="lazy"
            />
          </a>.
        </p>
        <p class="mt-8 mb-16 text-center">
          <a
            href="https://astro.build"
            target="_blank"
            rel="noopener noreferrer"
            class="focus-ring inline-block"
            ><img
              src="https://astro.badg.es/v2/built-with-astro/large.svg"
              alt="Built with Astro"
              width="288"
              height="48"
            /></a
          >
        </p>
      </div>

      <div class="grid gap-8 lg:grid-cols-2">
        <div class="text-sm font-medium">
          <ul class="flex justify-center gap-6 lg:justify-start">
            {
              footerNavItems.map((item) => {
                const isActive = currentPath === item.href
                return (
                  <li>
                    <a
                      href={item.href}
                      class:list={[
                        'focus-ring inline-block py-1',
                        { 'text-pink-700 dark:text-pink-400': isActive },
                      ]}
                      aria-current={isActive ? 'page' : undefined}
                    >
                      {item.name}
                    </a>
                  </li>
                )
              })
            }
          </ul>
        </div>
        <div class="">
          <p class="text-center text-sm font-medium lg:text-right">
            © {year} Florian van der Galiën. All rights reserved.
          </p>
        </div>
      </div>
    </div>
  </section>
</footer>
