---
import { getCollection } from 'astro:content'
import BlurredPicture from './BlurredPicture.astro'

const images = (await getCollection('grid')).sort((a, b) => {
  const dateComparison = b.data.date.getTime() - a.data.date.getTime()
  if (dateComparison === 0) {
    return b.id.localeCompare(a.id)
  }
  return dateComparison
})
---

<ul
  class="moments xs:grid-cols-2 -mx-4 grid grid-cols-1 gap-3 sm:mx-0 sm:grid-cols-3 lg:gap-6"
>
  {
    images.map((entry, i) => (
      <li class="moment -rotate-[0.1deg] -skew-x-[0.5deg] overflow-hidden rounded-lg shadow-xl shadow-slate-700/10 transition-all duration-150 hover:scale-105 hover:motion-safe:-rotate-1 dark:shadow-slate-950/20">
        <a
          href={`/grid/${entry.id}/`}
          class="relative block aspect-[4/5] overflow-hidden focus:outline-none"
          data-grid-link
        >
          <BlurredPicture
            image={entry.data.image}
            alt={entry.data.alt}
            width={700}
            height={875}
            loading={i < 3 ? 'eager' : 'lazy'}
            imgClass="relative h-full w-full object-cover object-center"
          />
        </a>
      </li>
    ))
  }
</ul>

<style>
  .moments {
    /* @supports (grid-template-rows: masonry) {
      grid-template-rows: masonry;
    }

    @supports not (grid-template-rows: masonry) {
      img {
        aspect-ratio: 4 / 5;
      }
    } */

    &:has(.moment:hover) {
      .moment:not(:hover) {
        opacity: 0.75;
      }
    }

    &:has(.moment a:focus-visible) {
      .moment:not(:has(a:focus-visible)) {
        opacity: 0.75;
      }
    }
  }

  .moment a[data-grid-link]:focus-visible::after {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    box-shadow:
      inset 0 0 0 3px #fff,
      inset 0 0 0 6px #0f172a;
  }
</style>

<script>
  const links = Array.from(
    document.querySelectorAll<HTMLAnchorElement>('a[data-grid-link]'),
  )

  links.forEach((l) => {
    l.addEventListener('click', () => {
      sessionStorage.setItem('from-grid', 'true')
    })
  })

  const focusAt = (idx: number) => {
    links[Math.max(0, Math.min(links.length - 1, idx))]?.focus()
  }

  const findVerticalNeighbor = (
    current: HTMLAnchorElement,
    direction: 1 | -1,
  ): HTMLAnchorElement | undefined => {
    const cur = current.getBoundingClientRect()
    const candidates = links
      .filter((el) => el !== current)
      .map((el) => ({ el, rect: el.getBoundingClientRect() }))
      .filter(({ rect }) =>
        direction === 1 ? rect.top > cur.bottom - 1 : rect.bottom < cur.top + 1,
      )
    if (candidates.length === 0) return undefined

    const targetRowTop =
      direction === 1
        ? Math.min(...candidates.map((c) => c.rect.top))
        : Math.max(...candidates.map((c) => c.rect.top))

    const sameRow = candidates.filter(
      (c) => Math.abs(c.rect.top - targetRowTop) < 4,
    )

    return sameRow.reduce((best, c) =>
      Math.abs(c.rect.left - cur.left) < Math.abs(best.rect.left - cur.left)
        ? c
        : best,
    ).el
  }

  document.addEventListener('keydown', (event) => {
    if (event.ctrlKey || event.metaKey || event.altKey || event.shiftKey) return

    const active = document.activeElement
    if (!(active instanceof HTMLAnchorElement)) return

    const idx = links.indexOf(active)
    if (idx < 0) return

    let handled = true
    switch (event.key) {
      case 'ArrowRight':
        focusAt(idx + 1)
        break
      case 'ArrowLeft':
        focusAt(idx - 1)
        break
      case 'Home':
        focusAt(0)
        break
      case 'End':
        focusAt(links.length - 1)
        break
      case 'ArrowDown':
        findVerticalNeighbor(active, 1)?.focus()
        break
      case 'ArrowUp':
        findVerticalNeighbor(active, -1)?.focus()
        break
      default:
        handled = false
    }

    if (handled) event.preventDefault()
  })
</script>
