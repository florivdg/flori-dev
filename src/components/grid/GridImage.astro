---
import { Picture } from 'astro:assets'
import type { CollectionEntry } from 'astro:content'
import { generateBlurPlaceholder } from '../../utils/placeholder'
import GridImageBackButton from './GridImageBackButton.vue'
import GridImageInfoOverlay from './GridImageInfoOverlay.vue'
import GridImageNavigation from './GridImageNavigation.vue'

interface Props {
  entry: CollectionEntry<'grid'>
  prev?: CollectionEntry<'grid'>
  next?: CollectionEntry<'grid'>
}

const { entry, prev, next } = Astro.props

const placeholder = await generateBlurPlaceholder(entry.data.image)
---

<div
  class="fixed inset-0 flex h-dvh w-full items-center justify-center bg-slate-50 px-2 py-3 dark:bg-gray-950"
>
  <div
    class="relative max-h-full max-w-full -rotate-[0.5deg] -skew-x-[0.5deg] overflow-hidden rounded-xl shadow-xl shadow-slate-700/10 dark:shadow-slate-950/20"
  >
    <img
      src={placeholder}
      alt=""
      aria-hidden="true"
      decoding="sync"
      fetchpriority="high"
      class="pointer-events-none absolute inset-0 h-full w-full scale-110 object-cover blur-xl"
    />

    <Picture
      src={entry.data.image}
      alt={entry.data.alt}
      width="1800"
      densities={[1, 2]}
      formats={['webp']}
      quality={60}
      pictureAttributes={{
        class: 'relative flex items-center justify-center',
      }}
      class="block h-auto max-h-[calc(100dvh-1.5rem)] w-auto max-w-[calc(100vw-1rem)] opacity-0 transition-opacity duration-500"
      loading="eager"
      data-grid-image
    />
  </div>

  <GridImageBackButton client:load />

  <GridImageInfoOverlay entry={entry} client:load />

  <GridImageNavigation prev={prev} next={next} client:load />
</div>

<script>
  const img = document.querySelector<HTMLImageElement>('[data-grid-image]')

  if (img) {
    const reveal = () => img.classList.remove('opacity-0')

    if (img.complete && img.naturalWidth > 0) {
      reveal()
    } else {
      img.addEventListener('load', reveal, { once: true })
    }
  }
</script>
