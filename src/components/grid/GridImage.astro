---
import type { CollectionEntry } from 'astro:content'
import BlurredPicture from './BlurredPicture.astro'
import GridImageBackButton from './GridImageBackButton.vue'
import GridImageInfoOverlay from './GridImageInfoOverlay.vue'
import GridImageNavigation from './GridImageNavigation.vue'

interface Props {
  entry: CollectionEntry<'grid'>
  prev?: CollectionEntry<'grid'>
  next?: CollectionEntry<'grid'>
}

const { entry, prev, next } = Astro.props

const { width, height } = entry.data.image
const aspectRatio = `${width} / ${height}`
const frameWidth = `min(calc(100vw - 1rem), calc((100dvh - 1.5rem) * ${width} / ${height}))`
---

<div
  class="fixed inset-0 flex h-dvh w-full items-center justify-center bg-slate-50 px-2 py-3 dark:bg-gray-950"
>
  <div
    style={{ aspectRatio, width: frameWidth }}
    class="relative -rotate-[0.5deg] -skew-x-[0.5deg] overflow-hidden rounded-xl shadow-xl shadow-slate-700/10 dark:shadow-slate-950/20"
  >
    <BlurredPicture
      image={entry.data.image}
      alt={entry.data.alt}
      width={1800}
      loading="eager"
      imgClass="block h-full w-full object-contain"
      pictureClass="relative block h-full w-full"
    />
  </div>

  <GridImageBackButton client:load />

  <GridImageInfoOverlay entry={entry} client:load />

  <GridImageNavigation prev={prev} next={next} client:load />
</div>
