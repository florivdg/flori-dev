---
import { getCollection } from 'astro:content'
import { Picture } from 'astro:assets'
import FluidContent from './FluidContent.astro'
import TagList from './reads/TagList.astro'
import { formatDate } from '../utils/formatters'

const [reads, photos] = await Promise.all([
  getCollection('reads', ({ data }) => {
    return import.meta.env.PROD ? data.draft !== true : true
  }).then((r) =>
    r
      .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
      .slice(0, 3),
  ),
  getCollection('grid').then((g) =>
    g
      .sort((a, b) => {
        const dateComparison = b.data.date.getTime() - a.data.date.getTime()
        if (dateComparison === 0) {
          return b.id.localeCompare(a.id)
        }
        return dateComparison
      })
      .slice(0, 3),
  ),
])

const [featuredRead, secondRead, thirdRead] = reads
const [firstPhoto, secondPhoto, thirdPhoto] = photos
---

<style>
  .bento-grid > * {
    @apply transition-all duration-150;
  }

  .bento-grid:has(:hover) > :not(:hover) {
    opacity: 0.75;
  }

  .img-fill picture {
    position: absolute;
    inset: 0;
    height: 100%;
    width: 100%;
  }
</style>

<FluidContent>
  <h2 class="mb-4 text-4xl font-black">Latest</h2>
  <p class="mb-8 text-xl lg:mb-12">
    Fresh from the <span class="highlight">keyboard</span> and the <span
      class="highlight">camera</span
    >.
  </p>

  <div
    class="bento-grid grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-3 lg:gap-6"
  >
    <a
      href={`/reads/${featuredRead.id}`}
      class="group flex -rotate-[0.1deg] -skew-x-[0.5deg] flex-col overflow-hidden rounded-lg shadow-xl shadow-slate-700/10 hover:scale-[1.02] hover:motion-safe:-rotate-1 md:col-span-2 dark:shadow-slate-950/20"
    >
      {
        featuredRead.data.image ? (
          <Picture
            src={featuredRead.data.image.src}
            alt={featuredRead.data.image.alt}
            formats={['avif', 'webp']}
            densities={[1, 2]}
            width={720}
            height={480}
            class="h-auto w-full object-cover"
            loading="lazy"
          />
        ) : (
          <div class="aspect-video bg-gradient-to-tr from-pink-500/20 to-blue-500/20 dark:from-pink-500/10 dark:to-blue-500/10" />
        )
      }
      <div
        class="flex flex-1 flex-col bg-slate-50 p-6 transition-colors duration-150 ease-in-out group-hover:bg-slate-200 md:p-8 dark:bg-slate-700 dark:group-hover:bg-slate-900"
      >
        <time
          datetime={featuredRead.data.pubDate.toISOString()}
          class="mb-2 inline-block text-xs font-semibold text-slate-500 dark:text-slate-300"
        >
          {formatDate(featuredRead.data.pubDate)}
        </time>
        <h3
          class="text-2xl font-extrabold text-balance hyphens-auto lg:text-3xl"
        >
          {featuredRead.data.title}
        </h3>
        {
          featuredRead.data.description ? (
            <p class="mt-3 text-lg text-slate-600 dark:text-slate-300">
              {featuredRead.data.description}
            </p>
          ) : undefined
        }
        <div class="mt-auto pt-4">
          <TagList tags={featuredRead.data.tags.slice(0, 3)} />
        </div>
      </div>
    </a>

    <a
      href={`/grid/${firstPhoto.id}/`}
      class="group relative block min-h-64 -rotate-[0.1deg] -skew-x-[0.5deg] overflow-hidden rounded-lg shadow-xl shadow-slate-700/10 hover:scale-105 hover:motion-safe:-rotate-1 lg:h-full dark:shadow-slate-950/20"
    >
      <Picture
        src={firstPhoto.data.image}
        alt={firstPhoto.data.alt}
        width={700}
        height={875}
        densities={[1, 2]}
        formats={['webp']}
        quality={60}
        class="aspect-[4/5] h-full w-full object-cover object-center lg:absolute lg:inset-0 lg:aspect-auto"
        loading="lazy"
      />
      <div
        class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-black/60 via-black/20 to-transparent p-4 pt-12 opacity-0 transition-opacity duration-150 group-hover:opacity-100"
      >
        <p class="font-mono text-sm font-semibold text-white">
          {firstPhoto.data.title}
        </p>
        {
          firstPhoto.data.location && (
            <p class="mt-1 text-xs text-white/70">{firstPhoto.data.location}</p>
          )
        }
      </div>
    </a>

    <a
      href={`/grid/${secondPhoto.id}/`}
      class="group relative block min-h-64 -rotate-[0.1deg] -skew-x-[0.5deg] overflow-hidden rounded-lg shadow-xl shadow-slate-700/10 hover:scale-105 hover:motion-safe:-rotate-1 lg:h-full dark:shadow-slate-950/20"
    >
      <Picture
        src={secondPhoto.data.image}
        alt={secondPhoto.data.alt}
        width={700}
        height={875}
        densities={[1, 2]}
        formats={['webp']}
        quality={60}
        class="aspect-[4/5] h-full w-full object-cover object-center lg:absolute lg:inset-0 lg:aspect-auto"
        loading="lazy"
      />
      <div
        class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-black/60 via-black/20 to-transparent p-4 pt-12 opacity-0 transition-opacity duration-150 group-hover:opacity-100"
      >
        <p class="font-mono text-sm font-semibold text-white">
          {secondPhoto.data.title}
        </p>
        {
          secondPhoto.data.location && (
            <p class="mt-1 text-xs text-white/70">
              {secondPhoto.data.location}
            </p>
          )
        }
      </div>
    </a>

    <a
      href={`/reads/${secondRead.id}`}
      class="group flex -rotate-[0.1deg] -skew-x-[0.5deg] flex-col overflow-hidden rounded-lg shadow-xl shadow-slate-700/10 hover:scale-[1.02] hover:motion-safe:-rotate-1 dark:shadow-slate-950/20"
    >
      {
        secondRead.data.image ? (
          <Picture
            src={secondRead.data.image.src}
            alt={secondRead.data.image.alt}
            formats={['avif', 'webp']}
            densities={[1, 2]}
            width={720}
            height={480}
            class="aspect-[3/2] w-full object-cover"
            loading="lazy"
          />
        ) : (
          <div class="aspect-[3/2] bg-gradient-to-tr from-pink-500/20 to-blue-500/20 dark:from-pink-500/10 dark:to-blue-500/10" />
        )
      }
      <div
        class="flex flex-1 flex-col bg-slate-50 p-5 transition-colors duration-150 ease-in-out group-hover:bg-slate-200 dark:bg-slate-700 dark:group-hover:bg-slate-900"
      >
        <time
          datetime={secondRead.data.pubDate.toISOString()}
          class="mb-2 inline-block text-xs font-semibold text-slate-500 dark:text-slate-300"
        >
          {formatDate(secondRead.data.pubDate)}
        </time>
        <h3 class="text-xl font-extrabold text-balance hyphens-auto">
          {secondRead.data.title}
        </h3>
        <div class="mt-auto pt-4">
          <TagList tags={secondRead.data.tags.slice(0, 3)} />
        </div>
      </div>
    </a>

    <a
      href={`/grid/${thirdPhoto.id}/`}
      class="group relative block min-h-64 -rotate-[0.1deg] -skew-x-[0.5deg] overflow-hidden rounded-lg shadow-xl shadow-slate-700/10 hover:scale-105 hover:motion-safe:-rotate-1 lg:h-full dark:shadow-slate-950/20"
    >
      <Picture
        src={thirdPhoto.data.image}
        alt={thirdPhoto.data.alt}
        width={700}
        height={875}
        densities={[1, 2]}
        formats={['webp']}
        quality={60}
        class="aspect-[4/5] h-full w-full object-cover object-center lg:absolute lg:inset-0 lg:aspect-auto"
        loading="lazy"
      />
      <div
        class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-black/60 via-black/20 to-transparent p-4 pt-12 opacity-0 transition-opacity duration-150 group-hover:opacity-100"
      >
        <p class="font-mono text-sm font-semibold text-white">
          {thirdPhoto.data.title}
        </p>
        {
          thirdPhoto.data.location && (
            <p class="mt-1 text-xs text-white/70">{thirdPhoto.data.location}</p>
          )
        }
      </div>
    </a>

    <a
      href={`/reads/${thirdRead.id}`}
      class="group flex -rotate-[0.1deg] -skew-x-[0.5deg] flex-col overflow-hidden rounded-lg shadow-xl shadow-slate-700/10 hover:scale-[1.02] hover:motion-safe:-rotate-1 md:col-span-2 md:flex-row lg:col-span-3 dark:shadow-slate-950/20"
    >
      <div
        class="img-fill relative aspect-video shrink-0 md:aspect-auto md:w-2/5"
      >
        {
          thirdRead.data.image ? (
            <Picture
              src={thirdRead.data.image.src}
              alt={thirdRead.data.image.alt}
              formats={['avif', 'webp']}
              densities={[1, 2]}
              width={720}
              height={480}
              class="absolute inset-0 h-full w-full object-cover"
              loading="lazy"
            />
          ) : (
            <div class="absolute inset-0 bg-gradient-to-tr from-pink-500/20 to-blue-500/20 dark:from-pink-500/10 dark:to-blue-500/10" />
          )
        }
      </div>
      <div
        class="flex flex-1 flex-col bg-slate-50 p-6 transition-colors duration-150 ease-in-out group-hover:bg-slate-200 md:p-8 dark:bg-slate-700 dark:group-hover:bg-slate-900"
      >
        <time
          datetime={thirdRead.data.pubDate.toISOString()}
          class="mb-2 inline-block text-xs font-semibold text-slate-500 dark:text-slate-300"
        >
          {formatDate(thirdRead.data.pubDate)}
        </time>
        <h3 class="text-2xl font-extrabold text-balance hyphens-auto">
          {thirdRead.data.title}
        </h3>
        {
          thirdRead.data.description ? (
            <p class="mt-3 text-lg text-slate-600 dark:text-slate-300">
              {thirdRead.data.description}
            </p>
          ) : undefined
        }
        <div class="mt-auto pt-4">
          <TagList tags={thirdRead.data.tags.slice(0, 3)} />
        </div>
      </div>
    </a>
  </div>

  <div class="mt-12 flex flex-wrap items-center justify-center gap-4">
    <a
      href="/reads/"
      class="inline-flex -skew-x-6 items-center rounded bg-gradient-to-tr from-pink-500 to-blue-500 px-8 py-2 font-mono font-semibold text-white transition-all duration-150 hover:z-10 hover:scale-150 hover:rotate-0 hover:skew-x-0 hover:shadow-2xl"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 20 20"
        fill="currentColor"
        class="mr-1 h-5 w-5"
      >
        <path
          d="M10.75 16.82A7.462 7.462 0 0115 15.5c.71 0 1.396.098 2.046.282A.75.75 0 0018 15.06V3.44a.75.75 0 00-.556-.724A9.006 9.006 0 0015 2.5a8.96 8.96 0 00-4.25 1.065v13.255zM9.25 4.75c0-.212.04-.416.116-.604A8.96 8.96 0 005 3.5a9.007 9.007 0 00-2.444.274.75.75 0 00-.556.724v11.62a.75.75 0 00.954.724A7.465 7.465 0 015 16.5a7.465 7.465 0 013.25.748V4.75z"
        ></path>
      </svg>
      <span>/reads/</span>
    </a>
    <a
      href="/grid/"
      class="inline-flex -skew-x-6 items-center rounded bg-gradient-to-tr from-pink-500 to-blue-500 px-8 py-2 font-mono font-semibold text-white transition-all duration-150 hover:z-10 hover:scale-150 hover:rotate-0 hover:skew-x-0 hover:shadow-2xl"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 20 20"
        fill="currentColor"
        class="mr-1 h-5 w-5"
      >
        <path
          fill-rule="evenodd"
          d="M1 5.25A2.25 2.25 0 013.25 3h13.5A2.25 2.25 0 0119 5.25v9.5A2.25 2.25 0 0116.75 17H3.25A2.25 2.25 0 011 14.75v-9.5zm1.5 5.81v3.69c0 .414.336.75.75.75h13.5a.75.75 0 00.75-.75v-2.69l-2.22-2.219a.75.75 0 00-1.06 0l-1.91 1.909-4.97-4.969a.75.75 0 00-1.06 0L2.5 11.06zm10-3.56a1.5 1.5 0 113 0 1.5 1.5 0 01-3 0z"
          clip-rule="evenodd"></path>
      </svg>
      <span>/grid/</span>
    </a>
  </div>
</FluidContent>
